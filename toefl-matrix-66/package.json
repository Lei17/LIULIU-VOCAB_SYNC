{
  "name": "toefl-matrix-66",
  "version": "1.0.0",
  "description": "TOEFL 66词矩阵记忆系统 - 赛博朋克风格背单词看板",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "electron:dev": "vite build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "rebuild": "electron-rebuild -v 22.3.27 -m .",
    "postinstall": "npx electron-rebuild -v 22.3.27 -m ."
  },
  "build": {
    "appId": "com.toefl.matrix66",
    "productName": "66背词看板",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "66背词看板"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@electron/rebuild": "^4.0.4",
    "electron": "^22.3.27",
    "electron-builder": "^26.0.0",
    "vite": "^6.3.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0"
  }
}
